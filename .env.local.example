# Copy this file to .env.local for local development.
# .env.local is gitignored and never deployed.
#
# The mock API is ON by default whenever NODE_ENV=development (i.e. npm run dev).
# No env vars are required for basic local development.
#
# To proxy to the real internal backend instead of returning mock data,
# add the line below (requires access to the internal network):
# MOCK_API=false
#
# Backend URL — set this on Vercel to your Cloudflare Tunnel hostname.
# Falls back to the internal hostname for local/on-prem development.
# BACKEND_BASE_URL=https://api-backend.yourdomain.com
#
# JWT secret for authenticating with the backend auth endpoint.
# JWT_SECRET=your-secret-here
