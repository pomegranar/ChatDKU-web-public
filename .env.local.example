# Copy this file to .env.local for local development.
# .env.local is gitignored and never deployed.
#
# The mock API is ON by default whenever NODE_ENV=development (i.e. npm run dev).
# No env vars are required for basic local development.
#
# To proxy to the real internal backend instead of returning mock data,
# add the line below (requires access to the internal network):
# MOCK_API=false
#
# ── Guest (public) backend ────────────────────────────────────────────────
# URL of the public FastAPI backend (Cloudflare Tunnel).
# Falls back to the internal hostname for local/on-prem development.
# BACKEND_BASE_URL=https://api.chatdku.com
#
# Shared secret for the public backend's /auth/get-token endpoint.
# JWT_SECRET=your-public-backend-secret-here
#
# ── NetID (Shibboleth) backend ────────────────────────────────────────────
# URL of the Django backend exposed via the api-auth Cloudflare Tunnel.
# Used for users who signed in with their DKU NetID.
# NETID_BACKEND_URL=https://api-auth.chatdku.com
#
# ── SSO redirect URL ──────────────────────────────────────────────────────
# The on-prem endpoint that starts the Shibboleth login flow.
# NEXT_PUBLIC_SSO_REDIRECT_URL=https://chatdku.dukekunshan.edu.cn/auth/sso-redirect
